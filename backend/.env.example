# 服务监听
BIND_ADDR=0.0.0.0:8080

# PostgreSQL 连接串
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/clash_bridge

# JWT 密钥，生产环境务必替换
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=168

# 对外可访问的本服务基础地址，用于生成订阅 URL 给前端展示
PUBLIC_BASE_URL=http://127.0.0.1:8080

# 上游订阅拉取超时(秒)
UPSTREAM_FETCH_TIMEOUT_SECS=20

# 后台自动刷新所有 enabled profile 的上游订阅的间隔(秒)
# 0 表示关闭自动刷新. 实际最小值会被钳为 60 秒.
AUTO_REFRESH_INTERVAL_SECS=3600

RUST_LOG=info,clash_bridge=debug
