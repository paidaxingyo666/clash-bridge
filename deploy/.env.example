# docker-compose 部署配置
# 1. cp .env.example .env
# 2. 把下面占位符 (<...>) 替换成实际值
# 3. docker compose up -d

# === 对外端口 ===
BACKEND_PORT=17877
FRONTEND_PORT=17878

# === 浏览器侧访问后端的地址 (打到用户电脑 / 客户端 Clash 上的 URL) ===
# 用户在自家电脑上访问后台和拉订阅时, 浏览器/Clash 会请求这个地址.
# 局域网部署可以填 http://<your-host-ip>:17877
# 公网部署填域名或公网 IP, 强烈建议套 HTTPS
NEXT_PUBLIC_API_BASE_URL=http://<your-host>:17877

# 后端在生成订阅 URL (返回给前端展示) 时拼接的 base
PUBLIC_BASE_URL=http://<your-host>:17877

# === DB ===
# 推荐: 跟宿主已有的 postgres 容器在同一 docker network, 通过容器名直连
# (在 docker-compose.yml 的 networks.pgnet 里把 external network 名改成你的)
DATABASE_URL=postgres://<db-user>:<db-password>@<pg-container-name>:5432/<db-name>

# === JWT ===
# 生产请用 openssl rand -base64 48 之类生成
JWT_SECRET=<change-me-please>
