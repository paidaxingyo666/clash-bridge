# 服务器部署 (192.168.0.177) 用的 docker-compose 配置
# 实际值在 deploy/.env 里 (.gitignore 排除)

# 对外端口
BACKEND_PORT=17877
FRONTEND_PORT=17878

# 给浏览器用的 API 地址 (浏览器跑在用户电脑上, 通过宿主 IP 访问后端)
NEXT_PUBLIC_API_BASE_URL=http://192.168.0.177:17877

# 后端生成订阅 URL 时拼接的 base
PUBLIC_BASE_URL=http://192.168.0.177:17877

# DB: 通过 docker network 用容器名访问 superagent-pg
DATABASE_URL=postgres://clash_bridge:CHANGEME@superagent-pg:5432/clash_bridge

# JWT 签名密钥 (生产请用 openssl rand -base64 48 之类生成)
JWT_SECRET=please-change-me
