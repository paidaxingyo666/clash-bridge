# standalone 部署 (postgres 也在容器里) 的 env 模板
# cp .env.standalone.example .env
# 把 <...> 占位填好后 docker compose -f docker-compose.standalone.yml up -d --build

# === 端口 ===
# 注意: standalone compose 把端口绑在 127.0.0.1, 不暴露公网.
# 要走 Cloudflare Tunnel, 不需要改下面端口;
# 要直接公网暴露, 改 docker-compose.standalone.yml 里的 ports.
BACKEND_PORT=17877
FRONTEND_PORT=17878

# === DB / JWT 密码 ===
# 生成: openssl rand -base64 24 | tr -d '/=+' | cut -c1-24
POSTGRES_PASSWORD=<random-strong-password>
JWT_SECRET=<another-random-strong-secret>

# === 对外可访问的地址 ===
# 走 Cloudflare Tunnel 时填 cf 给你的域名, 例如:
#   NEXT_PUBLIC_API_BASE_URL=https://api.your-domain.com
#   PUBLIC_BASE_URL=https://api.your-domain.com
# 直接本机 / 局域网测试时填 http://127.0.0.1:17877
NEXT_PUBLIC_API_BASE_URL=https://<api-host>
PUBLIC_BASE_URL=https://<api-host>

# === Cloudflare Tunnel ===
# 在 Cloudflare Zero Trust 后台创建 tunnel 拿到 token 后填上.
# 留空则不会启动 cloudflared 容器 (需要 --profile cloudflare 才会启).
CLOUDFLARE_TUNNEL_TOKEN=
